---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import DraftBadge from '../components/DraftBadge.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface SeriesInfo {
	id: string;
	title: string;
}

interface PrevNextPost {
	id: string;
	title: string;
}

type Props = Omit<CollectionEntry<'blog'>['data'], 'series'> & {
	series?: SeriesInfo;
	prevPost?: PrevNextPost | null;
	nextPost?: PrevNextPost | null;
};

const { title, description, pubDate, updatedDate, heroImage, series, prevPost, nextPost, draft } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				max-width: 960px;
				margin: auto;
				padding: 1em;
				color: var(--color-text);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--color-muted);
			}
			.last-updated-on {
				font-style: italic;
			}
			.series-link {
				margin-bottom: 0.5em;
				font-size: 0.95em;
			}
			.series-link a {
				color: rgb(var(--accent));
				text-decoration: none;
			}
			.series-link a:hover {
				text-decoration: underline;
			}
			.series-nav {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				margin: 1.5rem 0;
				padding: 1rem 0;
				border-top: 1px solid rgba(var(--gray), 0.2);
				border-bottom: 1px solid rgba(var(--gray), 0.2);
				font-size: 0.95em;
			}
			.series-nav a {
				color: rgb(var(--accent));
				text-decoration: none;
				max-width: 45%;
			}
			.series-nav a:hover {
				text-decoration: underline;
			}
			.series-nav .nav-prev::before {
				content: '← ';
			}
			.series-nav .nav-next {
				text-align: right;
				margin-left: auto;
			}
			.series-nav .nav-next::after {
				content: ' →';
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{series && (
							<div class="series-link">
								Part of: <a href={`/series/${series.id}/`}>{series.title}</a>
							</div>
						)}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<DraftBadge draft={draft} />
						<h1>{title}</h1>
						{(prevPost || nextPost) && (
							<nav class="series-nav" aria-label="Series navigation">
								{prevPost ? (
									<a class="nav-prev" href={`/blog/${prevPost.id}/`}>{prevPost.title}</a>
								) : (
									<span />
								)}
								{nextPost ? (
									<a class="nav-next" href={`/blog/${nextPost.id}/`}>{nextPost.title}</a>
								) : (
									<span />
								)}
							</nav>
						)}
						<hr />
					</div>
					<slot />
					{(prevPost || nextPost) && (
						<nav class="series-nav" aria-label="Series navigation">
							{prevPost ? (
								<a class="nav-prev" href={`/blog/${prevPost.id}/`}>{prevPost.title}</a>
							) : (
								<span />
							)}
							{nextPost ? (
								<a class="nav-next" href={`/blog/${nextPost.id}/`}>{nextPost.title}</a>
							) : (
								<span />
							)}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
