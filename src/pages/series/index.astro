---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getSeriesPosts } from '../../utils/series';
import { isPublished } from '../../utils/content';

const seriesList = (await getCollection('series', ({ data }) => isPublished(data))).sort(
	(a, b) => a.data.title.localeCompare(b.data.title),
);

const seriesWithCounts = await Promise.all(
	seriesList.map(async (s) => {
		const { posts } = await getSeriesPosts(s.id);
		return { series: s, postCount: posts.length };
	}),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Series" description="Multi-part deep dives into distributed systems topics." />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			.series-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			.series-card {
				display: flex;
				gap: 1.5rem;
				text-decoration: none;
				color: inherit;
				border-bottom: 1px solid rgba(var(--gray), 0.2);
				padding-bottom: 2rem;
			}
			.series-card:last-child {
				border-bottom: none;
				padding-bottom: 0;
			}
			.series-card img {
				width: 160px;
				height: 90px;
				object-fit: cover;
				border-radius: 8px;
				flex-shrink: 0;
			}
			.series-info {
				flex: 1;
			}
			.series-title {
				margin: 0 0 0.4em 0;
				font-size: 1.25em;
				color: var(--color-heading);
				line-height: 1.2;
			}
			.series-card:hover .series-title {
				color: var(--accent);
			}
			.series-description {
				margin: 0 0 0.5em 0;
				color: var(--color-text);
				font-size: 0.95em;
				line-height: 1.5;
			}
			.series-meta {
				font-size: 0.85em;
				color: var(--color-muted);
			}
			@media (max-width: 520px) {
				.series-card {
					flex-direction: column;
					gap: 0.75rem;
				}
				.series-card img {
					width: 100%;
					height: 180px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Series</h1>
			<ul class="series-list">
				{seriesWithCounts.map(({ series, postCount }) => (
					<li>
						<a href={`/series/${series.id}/`} class="series-card">
							{series.data.heroImage && (
								<Image
									width={320}
									height={180}
									src={series.data.heroImage}
									alt=""
								/>
							)}
							<div class="series-info">
								<h2 class="series-title">{series.data.title}</h2>
								<p class="series-description">{series.data.description}</p>
								<span class="series-meta">{postCount} {postCount === 1 ? 'post' : 'posts'}</span>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
