---
import { type CollectionEntry, getEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getSeriesPosts } from '../../utils/series';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

let series: { id: string; title: string } | undefined;
let prevPost: { id: string; title: string } | null = null;
let nextPost: { id: string; title: string } | null = null;

if (post.data.series) {
	const seriesEntry = await getEntry('series', post.data.series);
	if (seriesEntry) {
		series = { id: seriesEntry.id, title: seriesEntry.data.title };
		const { getPrevNext } = await getSeriesPosts(post.data.series);
		const nav = getPrevNext(post.id);
		prevPost = nav.prev;
		nextPost = nav.next;
	}
}
---

<BlogPost
	{...post.data}
	{series}
	prevPost={prevPost}
	nextPost={nextPost}
>
	<Content />
</BlogPost>
