---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Learning Distributed Systems in Public</h1>
			<p>
				I'm <strong>Rasheed Bustamam</strong>, an applications consultant specializing in web and
				mobile. This is where I document my journey learning distributed systems—the concepts,
				the trade-offs, and the things that don't make it into the happy-path diagrams.
			</p>
			<p>
				If you need help with web or mobile applications, visit
				<a href="https://bustamam.tech" target="_blank" rel="noreferrer">bustamam.tech</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
