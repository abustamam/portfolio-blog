---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import logoDark from '../assets/site/bustamam-tech-logo-dark.png';
import logoWhite from '../assets/site/bustamam-tech-logo-white.png';
---

<header>
	<nav>
		<a href="/" class="logo-link" aria-label={SITE_TITLE}>
			<img src={logoDark.src} alt={SITE_TITLE} class="logo logo-light" width={180} height={40} />
			<img src={logoWhite.src} alt={SITE_TITLE} class="logo logo-dark" width={180} height={40} />
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/series">Series</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<a href="https://bustamam.tech" target="_blank" rel="noreferrer">Portfolio</a>
		</div>
		<div class="nav-right">
			<a href="https://github.com/abustamam" target="_blank" class="github-link" aria-label="Go to Bustamam Technology's GitHub profile">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<button type="button" class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
				<span class="theme-icon sun" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
				</span>
				<span class="theme-icon moon" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
				</span>
			</button>
		</div>
	</nav>
</header>
<script>
	function initThemeToggle() {
		const html = document.documentElement;
		const btn = document.querySelector('.theme-toggle');
		if (!btn) return;

		btn.addEventListener('click', () => {
			const isDark = html.classList.toggle('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		});
	}
	initThemeToggle();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		box-shadow: var(--header-shadow);
	}
	.logo-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		padding: 0.75em 0.5em;
	}
	.logo {
		height: 2rem;
		width: auto;
		display: block;
	}
	.logo-dark {
		display: none;
	}
	html.dark .logo-light {
		display: none;
	}
	html.dark .logo-dark {
		display: block;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
		border-radius: 6px;
		color: rgb(var(--header-text));
		line-height: 0;
	}
	.theme-toggle:hover {
		background: rgba(var(--header-text), 0.1);
	}
	.theme-icon {
		display: block;
	}
	.theme-icon.moon {
		display: none;
	}
	html.dark .theme-icon.sun {
		display: none;
	}
	html.dark .theme-icon.moon {
		display: block;
	}
	nav a:not(.logo-link) {
		padding: 1em 0.5em;
		color: rgb(var(--header-text));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a:not(.logo-link).active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.github-link {
		display: flex;
		align-items: center;
		padding: 0.5em;
		border-radius: 6px;
		color: rgb(var(--header-text));
		text-decoration: none;
		line-height: 0;
	}
	.github-link:hover {
		background: rgba(var(--header-text), 0.1);
	}
</style>
